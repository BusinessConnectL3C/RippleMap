{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "env": {
    "DATABASE_URL": "@ripplemap-database-url",
    "NEXTAUTH_SECRET": "@ripplemap-nextauth-secret",
    "NEXTAUTH_URL": "@ripplemap-nextauth-url",
    "ARCGIS_CLIENT_ID": "@ripplemap-arcgis-client-id",
    "ARCGIS_CLIENT_SECRET": "@ripplemap-arcgis-client-secret",
    "ARCGIS_ORG_URL": "@ripplemap-arcgis-org-url",
    "ARCGIS_GROUP_ID": "@ripplemap-arcgis-group-id",
    "ARCGIS_OAUTH_REDIRECT_URI": "@ripplemap-arcgis-oauth-redirect-uri",
    "SALESFORCE_CLIENT_ID": "@ripplemap-salesforce-client-id",
    "SALESFORCE_CLIENT_SECRET": "@ripplemap-salesforce-client-secret",
    "SALESFORCE_INSTANCE_URL": "@ripplemap-salesforce-instance-url",
    "CLICKUP_API_TOKEN": "@ripplemap-clickup-api-token",
    "CLICKUP_SUPPORT_LIST_ID": "@ripplemap-clickup-support-list-id",
    "CLICKUP_WEBHOOK_SECRET": "@ripplemap-clickup-webhook-secret",
    "AWS_REGION": "@ripplemap-aws-region",
    "AWS_S3_BUCKET": "@ripplemap-aws-s3-bucket",
    "AWS_ACCESS_KEY_ID": "@ripplemap-aws-access-key-id",
    "AWS_SECRET_ACCESS_KEY": "@ripplemap-aws-secret-access-key",
    "TOKEN_ENCRYPTION_KEY": "@ripplemap-token-encryption-key"
  }
}
